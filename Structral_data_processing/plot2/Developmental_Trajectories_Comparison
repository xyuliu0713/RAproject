import pandas as pd
import numpy as np
import statsmodels.formula.api as smf
import matplotlib.pyplot as plt

# ========= ROI 分类 =========
log_rois = [
    "bankssts","fusiform","inferiorparietal",
    "parsopercularis","parstriangularis"
]

quad_rois = [
    "middletemporal","superiortemporal","supramarginal"
]

rois = log_rois + quad_rois

# ========= 计算函数 =========
def compute_mean_curve(file_path, structure_type):

    df = pd.read_csv(file_path)
    df = df[df["age"] > 0]

    # ========= preprocessing =========
    df["log_age"] = np.log(df["age"])
    df["age2"] = df["age"] ** 2

    age_range = np.linspace(df["age"].min(), df["age"].max(), 100)
    log_age_range = np.log(age_range)
    age2_range = age_range ** 2

    all_roi_percent = []

    # ========= ROI loop =========
    for roi in rois:

        print(f"Processing {roi} ({structure_type})")

        # ========= Cortical Thickness =========
        if structure_type == "quadratic":

            model = smf.mixedlm(
                f"{roi} ~ age + age2",
                df,
                groups=df["subject"],
                re_formula="~age"
            )
            result = model.fit(method="lbfgs")

            pred_df = pd.DataFrame({
                "age": age_range,
                "age2": age2_range
            })

        # ========= ALL OTHER STRUCTURES =========
        else:

            # Surface Area + others → ROI-specific decision
            if roi in quad_rois:

                model = smf.mixedlm(
                    f"{roi} ~ age + age2",
                    df,
                    groups=df["subject"],
                    re_formula="~age"
                )
                result = model.fit(method="lbfgs")

                pred_df = pd.DataFrame({
                    "age": age_range,
                    "age2": age2_range
                })

            else:  # log_rois + all other metrics

                model = smf.mixedlm(
                    f"{roi} ~ log_age",
                    df,
                    groups=df["subject"],
                    re_formula="~log_age"
                )
                result = model.fit(method="lbfgs")

                pred_df = pd.DataFrame({
                    "log_age": log_age_range
                })

        # ========= prediction =========
        y_pred = result.predict(pred_df)

        baseline = np.mean(y_pred[:5])
        percent_change = (y_pred - baseline) / baseline * 100

        all_roi_percent.append(percent_change.values)

    mean_percent = np.mean(np.array(all_roi_percent), axis=0)

    return age_range, mean_percent


# ========= datasets =========
files = {
    "Cortical Thickness": ("/Volumes/xyu/files/ds006169-2/structural_features/reorg/lh_thickness.csv", "quadratic"),

    "Surface Area": ("/Volumes/xyu/files/ds006169-2/structural_features/reorg/lh_area.csv", "mixed"),

    "Mean Curvature": ("/Volumes/xyu/files/ds006169-2/structural_features/reorg/lh_meancurv.csv", "log"),

    "White Matter Volume": ("/Volumes/xyu/files/ds006169-2/structural_features/reorg/lh_wmvolume.csv", "log"),

    "Gray Matter Volume": ("/Volumes/xyu/files/ds006169-2/structural_features/reorg/lh_gmvolume.csv", "log")
}

# ========= plot =========
plt.figure(figsize=(7, 5))

colors = ["black", "red", "blue", "green", "purple"]

for i, (label, (file_path, model_type)) in enumerate(files.items()):

    age, curve = compute_mean_curve(file_path, model_type)

    plt.plot(
        age,
        curve,
        linewidth=2,
        label=label,
        color=colors[i % len(colors)]
    )

plt.axhline(0, linestyle="--", linewidth=1)

plt.xlabel("Age (Months)")
plt.ylabel("% Change (from baseline)")
plt.title("Developmental Trajectories (Mixed Surface Models)")

plt.legend()
plt.tight_layout()

plt.show()