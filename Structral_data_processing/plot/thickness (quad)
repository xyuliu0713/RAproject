import pandas as pd
import numpy as np
import statsmodels.formula.api as smf
import matplotlib.pyplot as plt

# ========= 1. 读取数据 =========
df = pd.read_csv("/Volumes/xyu/files/ds006169-2/structural_features/reorg/lh_thickness.csv")

# ========= 2. quadratic age =========
df["age2"] = df["age"] ** 2   # ✅ 二次项

# ========= 3. ROI list =========
rois = [
    "bankssts",
    "fusiform",
    "inferiorparietal",
    "middletemporal",
    "parsopercularis",
    "parstriangularis",
    "superiortemporal",
    "supramarginal"
]


# ========= 5. loop =========
