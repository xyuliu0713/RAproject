
# the code below is adapted from https://yeatmanlab.github.io/pyAFQ/ 

import os
import os.path as op
import nibabel as nib
import numpy as np
import sys

from dipy.io.streamline import load_trk
from dipy.tracking.streamline import transform_streamlines

from fury import actor, window
from fury.colormap import create_colormap

# =========================

# 🔧 你只需要改这里

# =========================

dir_in = '/Volumes/xyu/ds006169-1'

dir_out = '/Volumes/xyu/output_figures'

tract = 'CST'   # 比如 CST / ILF

hem = 'L'       # L / R / ''

# =========================

# 🧠 遍历所有被试

# =========================

for sub_id in os.listdir(dir_in):

    if not sub_id.startswith('sub-'):

        continue

    print(f'\nProcessing {sub_id}')

    sub_path = op.join(dir_in, sub_id)

    # 找所有 session（不固定）

    sessions = [s for s in os.listdir(sub_path) if s.startswith('ses-')]

    if len(sessions) == 0:

        print('  No sessions found, skip')

        continue

    for ses_id in sessions:

        print(f'  Session: {ses_id}')

        # =========================

        # 📁 AFQ 路径（关键）

        # =========================

        afq_path = op.join(

            dir_in,

            'derivatives',

            'afq',

            sub_id,

            ses_id

        )

        if not op.exists(afq_path):

            print('  No AFQ output, skip')

            continue

        bundle_path = op.join(afq_path, 'clean_bundles')

        if not op.exists(bundle_path):

            print('  No bundles folder, skip')

            continue

        # =========================

        # 🧠 找 FA 文件

        # =========================

        fa_files = [f for f in os.listdir(afq_path)

                    if 'FA' in f and f.endswith('.nii.gz')]

        if len(fa_files) == 0:

            print('  No FA file, skip')

            continue

        fa_img = nib.load(op.join(afq_path, fa_files[0]))

        fa = fa_img.get_fdata()

        # =========================

        # 🧠 找 b0 文件

        # =========================

        b0_files = [f for f in os.listdir(afq_path)

                    if 'b0' in f and f.endswith('.nii.gz')]

        if len(b0_files) == 0:

            print('  No b0 file, skip')

            continue

        t1w_img = nib.load(op.join(afq_path, b0_files[0]))

        t1w = t1w_img.get_fdata()

        # =========================

        # 🧠 找 tract 文件

        # =========================

        trk_files = [f for f in os.listdir(bundle_path)

                     if tract in f and hem in f and f.endswith('.trk')]

        if len(trk_files) == 0:

            print(f'  No tract {tract}{hem}, skip')

            continue

        trk_file = trk_files[0]

        sft_trk = load_trk(op.join(bundle_path, trk_file), fa_img)

        # =========================

        # 🔁 坐标转换

        # =========================

        sft_trk.to_rasmm()

        trk_t1w = transform_streamlines(

            sft_trk.streamlines,

            np.linalg.inv(t1w_img.affine)

        )

        # =========================

        # 🎨 画 tract

        # =========================

        def lines_as_tubes(sl, line_width, **kwargs):

            line_actor = actor.line(sl, **kwargs)

            line_actor.GetProperty().SetRenderLinesAsTubes(1)

            line_actor.GetProperty().SetLineWidth(line_width)

            return line_actor

        color_trk = np.array((0, 0.8, 0.4))

        trk_actor = lines_as_tubes(trk_t1w, 8, colors=color_trk)

        # =========================

        # 📊 AFQ profile

        # =========================

        sft_trk.to_vox()

        trk_profile = afq_profile(fa, sft_trk.streamlines, affine=np.eye(4))

        print(f'  AFQ profile length: {len(trk_profile)}')

        # =========================

        # 🧠 背景切片

        # =========================

        def slice_volume(data, x=None, y=None, z=None):

            slicer_actors = []

            slicer_actor_z = actor.slicer(data)

            if z is not None:

                slicer_actor_z.display_extent(

                    0, data.shape[0] - 1,

                    0, data.shape[1] - 1,

                    z, z)

                slicer_actors.append(slicer_actor_z)

            if x is not None:

                slicer_actor_x = slicer_actor_z.copy()

                slicer_actor_x.display_extent(

                    x, x,

                    0, data.shape[1] - 1,

                    0, data.shape[2] - 1)

                slicer_actors.append(slicer_actor_x)

            return slicer_actors

        if hem in ['L', 'R']:

            slicers = slice_volume(t1w, x=t1w.shape[0] // 2)

        else:

            slicers = slice_volume(t1w, z=t1w.shape[-1] // 3)

        # =========================

        # 🎥 渲染

        # =========================

        scene = window.Scene()

        scene.add(trk_actor)

        for slicer in slicers:

            scene.add(slicer)

        # 相机角度

        if hem == 'L':

            scene.set_camera(position=(250, 30, 40),

                             focal_point=(55, 45, 30),

                             view_up=(0, 0, 1))

        elif hem == 'R':

            scene.set_camera(position=(-140, 43, 40),

                             focal_point=(55, 45, 30),

                             view_up=(0, 0, 1))

        else:

            scene.set_camera(position=(50, 40, 250),

                             focal_point=(55, 45, 30),

                             view_up=(0, 1, 0))

        scene.background((255, 255, 255))

        # =========================

        # 💾 保存

        # =========================

        os.makedirs(dir_out, exist_ok=True)

        out_file = op.join(

            dir_out,

            f'{sub_id}_{ses_id}_{tract}{hem}.png'

        )

        window.record(scene, out_path=out_file, size=(2400, 2400))

        print(f'  Saved: {out_file}')