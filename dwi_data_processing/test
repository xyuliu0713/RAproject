import shutil

from pathlib import Path

# ✅ FIXED SOURCE PATH (你刚刚指出的关键错误)

src_root = Path("/Volumes/xyu/ds006169/derivatives/mrtrix2")

# 输出

dst_root = Path("/Volumes/xyu/ds006169/derivatives/example_bids_subject")



def copy_if_match(files, keywords):

    """返回第一个匹配 keywords 的文件"""

    for f in files:

        name = f.name.lower()

        if all(k in name for k in keywords):

            return f

    return None

def safe_copy(src, dst):

    if src and src.exists():

        dst.parent.mkdir(parents=True, exist_ok=True)

        shutil.copy2(src, dst)

        print(f"✔ copied: {src.name} → {dst}")

    else:

        print(f"✖ missing: {dst.name}")

for sub in src_root.glob("sub-*"):

    for ses in sub.glob("ses-*"):

        print(f"\n📁 Processing {sub.name} {ses.name}")

        anat_dir = ses / "anat"

        dwi_dir = ses / "dwi"

        out_anat = dst_root / sub.name / ses.name / "anat"

        out_dwi = dst_root / sub.name / ses.name / "dwi"

        out_anat.mkdir(parents=True, exist_ok=True)

        out_dwi.mkdir(parents=True, exist_ok=True)

        anat_files = list(anat_dir.glob("*")) if anat_dir.exists() else []

        dwi_files = list(dwi_dir.glob("*")) if dwi_dir.exists() else []

        # ---------------- ANAT ----------------

        b0 = copy_if_match(dwi_files, ["b0"])

        safe_copy(b0, out_anat / "b0.nii.gz")

        t2 = copy_if_match(dwi_files, ["t2"])

        safe_copy(t2, out_anat / "t2BiascorrAcpc.nii.gz")

        mask = copy_if_match(anat_files, ["mask"])

        safe_copy(mask, out_anat / "t2BiasCorrAcpcResliced2dwi_mask.nii.gz")

        # ---------------- DWI ----------------

        tck = copy_if_match(dwi_files, ["tck"])

        safe_copy(tck, out_dwi / "tractography.tck")

print("\n✅ Done")